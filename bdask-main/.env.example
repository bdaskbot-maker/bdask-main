# ============================================
# BdAsk.com - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================

# --- REQUIRED ---

# Google Gemini AI (for chat + translation)
# Get key: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection
# Get free cluster: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bdask?retryWrites=true&w=majority

# CricketData.org (for live cricket scores)
# Get key: https://cricketdata.org/
CRICKET_DATA_API_KEY=your_cricket_api_key_here

# NewsData.io (for Bangladesh news)
# Get key: https://newsdata.io/
NEWS_DATA_API_KEY=your_newsdata_api_key_here

# --- OPTIONAL ---

# Football-Data.org (for football scores)
# Get key: https://www.football-data.org/
# FOOTBALL_API_KEY=your_football_api_key_here

# ExchangeRate-API (for currency exchange)
# Get key: https://www.exchangerate-api.com/
# EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# --- SERVER CONFIG ---

# Backend
PORT=5000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://bdask.com

# --- NOTE ---
# Prayer Times (Aladhan API) - No key needed (free)
# Weather (OpenMeteo API) - No key needed (free)
